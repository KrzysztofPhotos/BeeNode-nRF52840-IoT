west:
  command: 'C:\ncs\toolchains\c1a76fddb2\opt\bin\Scripts\west build --build-dir c:/ncs/BeeNode1/build_1 c:/ncs/BeeNode1 --pristine --board nrf52840dk/nrf52840'
